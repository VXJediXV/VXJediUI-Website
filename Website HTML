<script>
/* ════════════════════════════════
   PULSE WAVE BACKGROUND
════════════════════════════════ */
(function(){
  const c = document.getElementById('waveCanvas');
  const x = c.getContext('2d');
  function resize(){ c.width = innerWidth; c.height = innerHeight; }
  resize(); window.addEventListener('resize', resize);

  const W = [
    { col:'124,58,237',  spd:0.000008, amp:60,  fr:0.011, ph:0,   yR:0.28, al:0.38 },
    { col:'225,29,138',  spd:0.000012, amp:45,  fr:0.015, ph:2.0, yR:0.48, al:0.32 },
    { col:'255,255,255', spd:0.000006, amp:35,  fr:0.008, ph:4.1, yR:0.62, al:0.18 },
    { col:'168,85,247',  spd:0.00001,  amp:50,  fr:0.013, ph:1.2, yR:0.38, al:0.22 },
    { col:'244,114,182', spd:0.000014, amp:30,  fr:0.018, ph:3.3, yR:0.72, al:0.18 },
    { col:'255,255,255', spd:0.000007, amp:28,  fr:0.01,  ph:5.0, yR:0.18, al:0.14 },
    { col:'124,58,237',  spd:0.000016, amp:22,  fr:0.022, ph:0.8, yR:0.85, al:0.15 },
    { col:'255,255,255', spd:0.000005, amp:22,  fr:0.007, ph:2.7, yR:0.54, al:0.11 },
  ];

  function drawW(w, t){
    const H = c.height, WW = c.width, by = H * w.yR;
    x.beginPath(); x.moveTo(0, H);
    for(let i=0;i<=WW;i+=2){
      const y = by + Math.sin(i*w.fr + t*w.spd + w.ph)*w.amp
                   + Math.sin(i*w.fr*1.6 + t*w.spd*0.65 + w.ph+1)*(w.amp*0.38);
      x.lineTo(i,y);
    }
    x.lineTo(WW,H); x.closePath();
    const g = x.createLinearGradient(0,by-w.amp,0,by+w.amp*2.2);
    g.addColorStop(0,   `rgba(${w.col},${w.al})`);
    g.addColorStop(0.5, `rgba(${w.col},${w.al*0.5})`);
    g.addColorStop(1,   `rgba(${w.col},0)`);
    x.fillStyle = g; x.fill();
  }

  function loop(ts){ x.clearRect(0,0,c.width,c.height); W.forEach(w=>drawW(w,ts)); requestAnimationFrame(loop); }
  requestAnimationFrame(loop);
})();

/* ════════════════════════════════
   CURSOR TRAIL
════════════════════════════════ */
(function(){
  const c = document.getElementById('trailCanvas');
  const x = c.getContext('2d');
  function resize(){ c.width = innerWidth; c.height = innerHeight; }
  resize(); window.addEventListener('resize', resize);

  const N = 30; const trail = [];
  let mx=-200, my=-200, cx=-200, cy=-200;
  document.addEventListener('mousemove', e=>{ mx=e.clientX; my=e.clientY; });
  function lerp(a,b,t){ return a+(b-a)*t; }

  function tick(){
    x.clearRect(0,0,c.width,c.height);
    cx = lerp(cx,mx,0.16); cy = lerp(cy,my,0.16);
    trail.unshift({x:cx,y:cy});
    if(trail.length>N) trail.pop();

    for(let i=0;i<trail.length;i++){
      const r  = 1-i/trail.length;
      const sz = r*5.5+0.4;
      const al = r*0.82;
      const t2 = i/trail.length;
      const rr = Math.round(lerp(168,225,t2));
      const gg = Math.round(lerp(85, 29, t2));
      const bb = Math.round(lerp(247,138,t2));
      x.beginPath();
      x.arc(trail[i].x, trail[i].y, sz, 0, Math.PI*2);
      x.fillStyle = `rgba(${rr},${gg},${bb},${al})`;
      x.fill();
    }
    // cursor dot
    x.beginPath(); x.arc(cx,cy,5.5,0,Math.PI*2);
    const g = x.createRadialGradient(cx,cy,0,cx,cy,5.5);
    g.addColorStop(0,'rgba(255,255,255,0.95)');
    g.addColorStop(1,'rgba(168,85,247,0)');
    x.fillStyle=g; x.fill();
    requestAnimationFrame(tick);
  }
  tick();
})();

/* ════════════════════════════════
   CLICK BURST
════════════════════════════════ */
(function(){
  const c = document.getElementById('burstCanvas');
  const x = c.getContext('2d');
  function resize(){ c.width=innerWidth; c.height=innerHeight; }
  resize(); window.addEventListener('resize',resize);

  const parts=[];
  const COLS=['124,58,237','168,85,247','225,29,138','244,114,182','255,255,255','200,100,255'];

  window.addEventListener('click', e=>{
    const n=24;
    for(let i=0;i<n;i++){
      const a = (Math.PI*2/n)*i + (Math.random()-.5)*0.6;
      const s = 2.5+Math.random()*5;
      parts.push({
        x:e.clientX, y:e.clientY,
        vx:Math.cos(a)*s, vy:Math.sin(a)*s,
        al:1, sz:2+Math.random()*3.5,
        col:COLS[Math.floor(Math.random()*COLS.length)],
        dec:0.028+Math.random()*0.022,
        gv:0.07+Math.random()*0.07
      });
    }
  });

  function tick(){
    x.clearRect(0,0,c.width,c.height);
    for(let i=parts.length-1;i>=0;i--){
      const p=parts[i];
      p.x+=p.vx; p.y+=p.vy; p.vy+=p.gv; p.vx*=0.97; p.al-=p.dec;
      if(p.al<=0){ parts.splice(i,1); continue; }
      x.beginPath(); x.arc(p.x,p.y,p.sz*p.al,0,Math.PI*2);
      x.shadowColor=`rgba(${p.col},0.9)`; x.shadowBlur=10;
      x.fillStyle=`rgba(${p.col},${p.al})`; x.fill(); x.shadowBlur=0;
    }
    requestAnimationFrame(tick);
  }
  tick();
})();

/* ════════════════════════════════
   SCROLL REVEAL
════════════════════════════════ */
const reveals = document.querySelectorAll('.reveal');
new IntersectionObserver((entries)=>{
  entries.forEach((e,i)=>{ if(e.isIntersecting){ setTimeout(()=>e.target.classList.add('visible'),i*80); } });
},{threshold:0.1}).observe
// fix: observe each element individually
const io = new IntersectionObserver((entries)=>{
  entries.forEach((e,i)=>{ if(e.isIntersecting){ setTimeout(()=>e.target.classList.add('visible'),i*80); io.unobserve(e.target); } });
},{threshold:0.1});
reveals.forEach(el=>io.observe(el));

/* ════════════════════════════════
   DONATE AMOUNT SELECTOR
════════════════════════════════ */
function setAmount(btn,val){
  document.querySelectorAll('.amount-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('customAmount').value=val;
}
</script>

