  --bg:         #08060f;
  --surface:    #100d1c;
  --border:     #2a1f4a;
  --border2:    #3d2b6b;

  --violet:     #7c3aed;
  --violet-lt:  #a855f7;
  --violet-dim: #3b1d6b;
  --magenta:    #e11d8a;
  --magenta-lt: #f472b6;
  --magenta-dim:#6b1040;

  --text:  #f0eeff;
  --muted: #6b5fa0;

  --glow-v: rgba(124,58,237,0.55);
  --glow-m: rgba(225,29,138,0.55);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  font-weight: 400;
  line-height: 1.6;
  overflow-x: hidden;
  cursor: none;
}

#waveCanvas, #trailCanvas, #burstCanvas {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  pointer-events: none;
}
#waveCanvas  { z-index: 0; opacity: 0.6; }
#trailCanvas { z-index: 9999; }
#burstCanvas { z-index: 9998; }

nav, section, .stats, footer, .divider { position: relative; z-index: 1; }

/* NAV */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.25rem 3rem;
  background: rgba(8,6,15,0.85);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
}

.nav-logo {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-decoration: none;
  background: linear-gradient(90deg, var(--violet-lt), var(--magenta-lt));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.nav-links { display: flex; gap: 2.5rem; list-style: none; }
.nav-links a {
  color: var(--muted);
  text-decoration: none;
  font-family: var(--font-display);
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 500;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--violet-lt); }

/* BUTTONS */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.7rem 1.6rem;
  border-radius: 3px;
  font-family: var(--font-display);
  font-size: 0.65rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 700;
  text-decoration: none;
  cursor: none;
  transition: all 0.2s;
  border: none;
}
.btn-primary {
  background: linear-gradient(135deg, var(--violet), var(--magenta));
  color: #fff;
  box-shadow: 0 0 20px var(--glow-v), 0 0 40px rgba(225,29,138,0.15);
}
.btn-primary:hover {
  box-shadow: 0 0 35px var(--glow-v), 0 0 60px var(--glow-m);
  transform: translateY(-2px);
  filter: brightness(1.15);
}
.btn-ghost {
  background: transparent;
  color: var(--muted);
  border: 1px solid var(--border2);
}
.btn-ghost:hover { color: var(--violet-lt); border-color: var(--violet-lt); box-shadow: 0 0 15px rgba(124,58,237,0.25); }

/* HERO */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 8rem 3rem 5rem;
  position: relative;
  overflow: hidden;
}

.hero-eyebrow {
  font-family: var(--font-display);
  font-size: 0.62rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  font-weight: 500;
  background: linear-gradient(90deg, var(--violet-lt), var(--magenta-lt));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 1.75rem;
  opacity: 0;
  animation: fadeUp 0.7s ease forwards 0.1s;
}

.hero h1 {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 6.5vw, 5.5rem);
  font-weight: 900;
  line-height: 1.06;
  letter-spacing: 0.03em;
  text-transform: uppercase;
  max-width: 16ch;
  opacity: 0;
  animation: fadeUp 0.8s ease forwards 0.2s;
}
.hero h1 em {
  font-style: normal;
  background: linear-gradient(135deg, var(--violet-lt), var(--magenta));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  filter: drop-shadow(0 0 22px var(--glow-m));
}

.hero-sub {
  margin-top: 2rem;
  font-size: 1rem;
  color: var(--muted);
  max-width: 44ch;
  line-height: 1.7;
  font-weight: 400;
  opacity: 0;
  animation: fadeUp 0.8s ease forwards 0.35s;
}

.hero-actions {
  margin-top: 3rem;
  display: flex;
  gap: 1rem;
  opacity: 0;
  animation: fadeUp 0.8s ease forwards 0.5s;
}

/* STATS */
.stats {
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 2rem 3rem;
  display: flex;
  gap: 4rem;
  background: rgba(16,13,28,0.65);
  backdrop-filter: blur(8px);
  opacity: 0;
  animation: fadeUp 0.8s ease forwards 0.65s;
}
.stat-num {
  font-family: var(--font-display);
  font-size: 2.1rem;
  font-weight: 700;
  line-height: 1;
  background: linear-gradient(135deg, var(--violet-lt), var(--magenta-lt));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.stat-label {
  font-family: var(--font-display);
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-weight: 500;
  color: var(--muted);
  margin-top: 0.3rem;
}

/* SECTIONS */
section { padding: 6rem 3rem; }

.section-eyebrow {
  font-family: var(--font-display);
  font-size: 0.6rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--magenta);
  margin-bottom: 1rem;
}
.section-title {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3.5vw, 2.8rem);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  line-height: 1.1;
  max-width: 22ch;
}

/* ADDON GRID */
.addons-grid {
  margin-top: 3.5rem;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
}
.addon-card {
  background: var(--surface);
  padding: 2rem 2.25rem;
  position: relative;
  overflow: hidden;
  transition: background 0.25s;
}
.addon-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(124,58,237,0.05), rgba(225,29,138,0.05));
  opacity: 0;
  transition: opacity 0.3s;
}
.addon-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--violet), var(--magenta));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.35s ease;
}
.addon-card:hover { background: #13102a; }
.addon-card:hover::before { opacity: 1; }
.addon-card:hover::after  { transform: scaleX(1); }

.addon-tag {
  display: inline-block;
  font-family: var(--font-display);
  font-size: 0.55rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 700;
  padding: 0.22rem 0.6rem;
  border-radius: 2px;
  margin-bottom: 1.25rem;
}
.tag-combat { background: rgba(225,29,138,0.18); color: var(--magenta-lt); border: 1px solid rgba(225,29,138,0.3); }
.tag-ui     { background: rgba(124,58,237,0.18); color: var(--violet-lt);  border: 1px solid rgba(124,58,237,0.3); }
.tag-util   { background: rgba(168,85,247,0.15); color: #c084fc;           border: 1px solid rgba(168,85,247,0.25); }
.tag-raid   { background: rgba(244,114,182,0.15); color: #f9a8d4;          border: 1px solid rgba(244,114,182,0.25); }

.addon-name {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 0.6rem;
}
.addon-desc { font-size: 0.9rem; color: var(--muted); line-height: 1.65; margin-bottom: 1.5rem; }

.addon-features { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.5rem; }
.feature-pill {
  font-family: var(--font-display);
  font-size: 0.55rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 600;
  padding: 0.2rem 0.5rem;
  border: 1px solid var(--border2);
  border-radius: 2px;
  color: var(--muted);
}

.addon-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 1.25rem;
  border-top: 1px solid var(--border);
}
.addon-version { font-family: var(--font-display); font-size: 0.6rem; color: var(--muted); letter-spacing: 0.07em; }
.addon-dl {
  display: flex; align-items: center; gap: 0.4rem;
  font-family: var(--font-display);
  font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700;
  background: linear-gradient(90deg, var(--violet-lt), var(--magenta-lt));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  text-decoration: none; transition: filter 0.2s;
}
.addon-dl:hover { filter: brightness(1.3); }

/* FEATURED */
.featured {
  background: var(--surface);
  border: 1px solid var(--border2);
  display: grid;
  grid-template-columns: 1fr 1fr;
  overflow: hidden;
  box-shadow: 0 0 60px rgba(124,58,237,0.1), 0 0 40px rgba(225,29,138,0.07);
}
.featured-content { padding: 3.5rem; border-right: 1px solid var(--border); }
.featured-badge {
  font-family: var(--font-display);
  font-size: 0.55rem; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 700;
  color: var(--magenta-lt);
  border: 1px solid var(--magenta-dim);
  display: inline-block; padding: 0.22rem 0.6rem; border-radius: 2px; margin-bottom: 1.5rem;
}
.featured h3 {
  font-family: var(--font-display);
  font-size: 2.3rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.06em; line-height: 1.1; margin-bottom: 1rem;
  background: linear-gradient(135deg, var(--text), var(--violet-lt));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.featured p { color: var(--muted); font-size: 0.9rem; line-height: 1.75; margin-bottom: 1.25rem; }

.featured-stats { padding: 3.5rem; display: flex; flex-direction: column; justify-content: center; gap: 2rem; }
.fstat { display: flex; align-items: center; gap: 1.25rem; }
.fstat-bar-wrap { flex: 1; height: 2px; background: var(--border); border-radius: 1px; overflow: hidden; }
.fstat-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--violet), var(--magenta));
  border-radius: 1px;
  box-shadow: 0 0 8px var(--glow-v);
  animation: barGrow 1.2s ease forwards;
  transform-origin: left;
}
@keyframes barGrow { from { transform: scaleX(0); } to { transform: scaleX(1); } }
.fstat-label { font-family: var(--font-display); font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; color: var(--muted); width: 9ch; }
.fstat-val   { font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; color: var(--violet-lt); width: 4ch; text-align: right; }

/* INSTALL */
.install-section { background: var(--surface); border: 1px solid var(--border); padding: 3rem 3.5rem; }
.install-steps { display: grid; grid-template-columns: repeat(3,1fr); gap: 2rem; margin-top: 2.5rem; }
.step-num { font-family: var(--font-display); font-size: 3rem; font-weight: 900; color: var(--border2); line-height: 1; margin-bottom: 1rem; }
.step-title { font-family: var(--font-display); font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; }
.step-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.65; }
code {
  font-family: var(--font-body);
  font-size: 0.8rem;
  background: rgba(124,58,237,0.12);
  border: 1px solid rgba(124,58,237,0.25);
  padding: 0.1rem 0.4rem;
  border-radius: 2px;
  color: var(--violet-lt);
}

/* DONATE */
.donate-section {
  background: var(--surface); border: 1px solid var(--border2); overflow: hidden;
  box-shadow: 0 0 60px rgba(225,29,138,0.07);
}
.donate-inner { display: grid; grid-template-columns: 1fr 1fr; }
.donate-left { padding: 3.5rem; border-right: 1px solid var(--border); }
.donate-left h3 { font-family: var(--font-display); font-size: 1.9rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.04em; line-height: 1.15; margin-bottom: 1rem; }
.donate-left h3 em {
  font-style: normal;
  background: linear-gradient(90deg, var(--violet-lt), var(--magenta-lt));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.donate-left p { color: var(--muted); font-size: 0.875rem; line-height: 1.75; margin-bottom: 1.5rem; }

.donate-perks { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; margin-bottom: 2rem; }
.donate-perks li { display: flex; align-items: center; gap: 0.75rem; font-size: 0.82rem; color: var(--muted); font-family: var(--font-display); letter-spacing: 0.03em; }
.perk-dot { width: 5px; height: 5px; border-radius: 50%; background: linear-gradient(135deg, var(--violet), var(--magenta)); flex-shrink: 0; box-shadow: 0 0 6px var(--glow-m); }

.donate-right { padding: 3.5rem; display: flex; flex-direction: column; gap: 1rem; }
.donate-right-title { font-family: var(--font-display); font-size: 0.6rem; letter-spacing: 0.16em; text-transform: uppercase; font-weight: 600; color: var(--muted); margin-bottom: 0.5rem; }

.amount-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.6rem; margin-bottom: 0.5rem; }
.amount-btn {
  background: transparent; border: 1px solid var(--border2); color: var(--muted);
  font-family: var(--font-display); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.06em;
  padding: 0.7rem 0; border-radius: 3px; cursor: none; transition: all 0.18s; text-align: center;
}
.amount-btn:hover, .amount-btn.active {
  border-color: var(--violet-lt); color: var(--violet-lt);
  background: rgba(124,58,237,0.1); box-shadow: 0 0 12px rgba(124,58,237,0.2);
}

.donate-custom-wrap { position: relative; }
.donate-custom-wrap .currency { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); font-family: var(--font-display); font-size: 0.85rem; color: var(--muted); }
.donate-custom {
  width: 100%; background: transparent; border: 1px solid var(--border); color: var(--text);
  font-family: var(--font-display); font-size: 0.9rem;
  padding: 0.75rem 1rem 0.75rem 2rem; border-radius: 3px; outline: none; transition: border-color 0.18s;
}
.donate-custom:focus { border-color: var(--violet); box-shadow: 0 0 10px rgba(124,58,237,0.2); }
.donate-custom::placeholder { color: var(--muted); }

.donate-platforms { display: flex; flex-direction: column; gap: 0.6rem; margin-top: 0.5rem; }
.platform-btn {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0.9rem 1.25rem; border-radius: 3px; text-decoration: none;
  font-family: var(--font-display); font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700;
  transition: all 0.18s; border: 1px solid transparent; cursor: none;
}
.platform-btn .plabel { display: flex; align-items: center; gap: 0.6rem; }
.platform-btn .parrow { opacity: 0.5; transition: transform 0.18s, opacity 0.18s; }
.platform-btn:hover .parrow { transform: translateX(4px); opacity: 1; }
.btn-paypal  { background: rgba(0,112,186,0.1);  color: #60aadf; border-color: rgba(0,112,186,0.2);  }
.btn-paypal:hover  { background: rgba(0,112,186,0.2);  box-shadow: 0 0 14px rgba(0,112,186,0.3); }
.btn-kofi   { background: rgba(255,94,91,0.1);  color: #e07878; border-color: rgba(255,94,91,0.2);  }
.btn-kofi:hover   { background: rgba(255,94,91,0.18); box-shadow: 0 0 14px rgba(255,94,91,0.3);  }
.btn-patreon { background: rgba(255,66,77,0.08); color: #c07878; border-color: rgba(255,66,77,0.15); }
.btn-patreon:hover { background: rgba(255,66,77,0.15); box-shadow: 0 0 14px rgba(255,66,77,0.25); }
.donate-note { font-family: var(--font-display); font-size: 0.6rem; letter-spacing: 0.08em; color: var(--muted); text-align: center; margin-top: 0.25rem; }

/* DIVIDER */
.divider { border: none; border-top: 1px solid var(--border); margin: 0 3rem; position: relative; z-index: 1; }

/* FOOTER */
footer { border-top: 1px solid var(--border); padding: 2.5rem 3rem; display: flex; align-items: center; justify-content: space-between; background: rgba(8,6,15,0.8); }
.footer-logo {
  font-family: var(--font-display); font-size: 1rem; font-weight: 700; letter-spacing: 0.14em;
  background: linear-gradient(90deg, var(--violet-lt), var(--magenta-lt));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.footer-note { font-family: var(--font-display); font-size: 0.6rem; letter-spacing: 0.08em; color: var(--muted); }
.footer-links { display: flex; gap: 2rem; list-style: none; }
.footer-links a {
  font-family: var(--font-display); font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
  color: var(--muted); text-decoration: none; transition: color 0.2s;
}
.footer-links a:hover { color: var(--violet-lt); }

/* ANIMATIONS */
@keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:none; } }
.reveal { opacity:0; transform:translateY(22px); transition: opacity 0.65s ease, transform 0.65s ease; }
.reveal.visible { opacity:1; transform:none; }

/* RESPONSIVE */
@media (max-width: 768px) {
  nav { padding: 1rem 1.5rem; }
  .nav-links { display: none; }
  .hero { padding: 7rem 1.5rem 3rem; }
  .stats { padding: 1.5rem; gap: 2rem; flex-wrap: wrap; }
  section { padding: 4rem 1.5rem; }
  .featured { grid-template-columns: 1fr; }
  .featured-content { border-right: none; border-bottom: 1px solid var(--border); }
  .install-steps { grid-template-columns: 1fr; }
  .donate-inner { grid-template-columns: 1fr; }
  .donate-left { border-right: none; border-bottom: 1px solid var(--border); padding: 2rem 1.5rem; }
  .donate-right { padding: 2rem 1.5rem; }
  footer { flex-direction: column; gap: 1.5rem; text-align: center; }
  .divider { margin: 0 1.5rem; }
  body { cursor: auto; }
}
